# Same directory as manage.py (`ecb_website/.env`). Copy to .env and edit; never commit .env.

# --- Django core ---
SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost
# Comma-separated; include scheme — e.g. http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- Database ---
# Leave unset to use SQLite: ecb_website/db.sqlite3
# PostgreSQL example (use your host/db/user):
# DATABASE_URL=postgresql://ecb:secret@127.0.0.1:5432/executivecoachbuilders

# --- LLM (portal/agent; DB AgentSettings in Settings UI overrides when saved) ---
# Choose which provider is active if not set in DB: openai | gemini | deepseek | openrouter
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Outbound / inbound mail (optional fallback; Portal → Settings → Sales email overrides DB row) ---
SMTP_ENABLED=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=

IMAP_ENABLED=0
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=1
IMAP_FOLDER=INBOX

EMAIL_INTERNAL_DOMAINS=ecblimo.com

# --- Files on disk (single server); optional. Default media = ecb_website/media
# MEDIA_ROOT=/var/lib/executivecoachbuilders/media
# STATIC_ROOT=/var/lib/executivecoachbuilders/static
